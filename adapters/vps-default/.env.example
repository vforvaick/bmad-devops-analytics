# Required identity values for the automated VPS adapter.
BDA_VPS_APP_LABEL=api
BDA_VPS_SENTRY_ORG=acme
BDA_VPS_SENTRY_PROJECT=web-app

# Optional override. Defaults to BDA_VPS_APP_LABEL when omitted.
# BDA_VPS_JAEGER_SERVICE_NAME=api

# Service locations. Defaults assume the observability stack runs on the same host.
PROMETHEUS_URL=http://localhost:9090
LOKI_URL=http://localhost:3100
SENTRY_URL=http://localhost:9000
JAEGER_URL=http://localhost:16686
POSTHOG_URL=http://localhost:8000

# Access tokens for vendor APIs.
SENTRY_TOKEN=replace-me
POSTHOG_API_KEY=replace-me

# Optional request timeout override in milliseconds.
# BDA_VPS_REQUEST_TIMEOUT_MS=5000
